    "fontWeights": {
      "regular": 420,
      "medium": 550,
      "display": 650
    },
    "letterSpacing": {
      "meta": 0.08,
      "display": -0.04
    },
    "lineHeights": {
      "body": 1.5,
      "display": 0.96
    }
  },
  "shadows": {
    "floating-panel": "0 24px 64px rgb(25 26 23 / 0.10)"
  },
  "borders": {
    "hairline": "1px solid #D7D2C5",
    "ink": "1px solid #191A17"
  },
  "durations": {
    "micro": 120,
    "short": 180,
    "medium": 240
  },
  "easing": {
    "standard": "cubic-bezier(.2,.8,.2,1)"
