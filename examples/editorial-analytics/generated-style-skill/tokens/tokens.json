{
  "colors": {
    "canvas": "#F4F1E8",
    "surface": "#FFFEFA",
    "ink": "#191A17",
    "muted": "#686A62",
    "line": "#D7D2C5",
    "cobalt": "#3157F5",
    "signal": "#DDF45A",
    "coral": "#F05A3C",
    "success": "#1E7A55"
  },
  "spacing": {
    "unit": 4,
    "2xs": 8,
    "xs": 12,
    "sm": 16,
    "md": 24,
    "lg": 32,
    "xl": 48,
    "2xl": 72
  },
  "radii": {
    "control": 4,
    "card": 8,
    "panel": 14
  },
  "typography": {
    "fontFamilies": {
      "display": "General Sans, Source Han Sans SC, sans-serif",
      "body": "Instrument Sans, Source Han Sans SC, sans-serif",
      "mono": "IBM Plex Mono, Cascadia Code, monospace"
    },
    "fontSizes": {
      "meta": 12,
      "body": 16,
      "subhead": 22,
      "section": 38,
      "hero": 72
