{
  "name": "ui-to-prompt",
  "version": "0.1.0",
  "description": "Turn webpages and images into evidence-backed, reusable systematic design prompts and AI Skills.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/derrickgong87/ui-to-prompt#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/derrickgong87/ui-to-prompt.git"
  },
  "bugs": {
    "url": "https://github.com/derrickgong87/ui-to-prompt/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "2.11.0",
    "playwright": "1.61.1"
  },
  "scripts": {
    "start": "node apps/web/server.mjs",
    "test": "node --test",
    "test:skill": "python tests/test_skill_scripts.py -v",
    "verify": "npm test && npm run test:skill",
    "package:review": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-release.ps1",
    "vercel-build": "node scripts/build-vercel.mjs"
  },
  "keywords": [
    "systematic-prompt",
    "design-system",
    "ai-skill",
    "web-forensics",
    "ui-analysis"
  ],
  "author": "Derrick Gong and contributors"
}
