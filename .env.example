# Copy these names to your hosting provider. Never commit a real key.
NODE_ENV=production
PORT=8080
HOST=0.0.0.0
PUBLIC_APP_ORIGIN=https://uitoprompt.com

# Set this only in Secret Manager / the provider's encrypted environment store.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_MS=60000
MAX_IMAGE_BYTES=3145728
MAX_IMAGE_PIXELS=20000000

# Keep false in public deployments until the separate browser worker and egress controls exist.
URL_ANALYSIS_ENABLED=false
